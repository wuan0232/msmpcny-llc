        <mxCell id="r_admin" parent="r_ext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=12;fontStyle=1;fontColor=#333333;" value="角色 C：内容管理员&#xa;(Content Admin @ AIHostHub)&#xa;&#xa;• 在 AIHostHub 后台管理 Blog&#xa;• 发布/编辑/下架文章 msmpcny 站点&#xa;• 上传图片&#xa;• 不直接操作本官网代码" vertex="1">
