        <mxCell id="b_fetch" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="fetchBlogPosts&#xa;GET /api/blog/sites/msmpcny/posts&#xa;page=1..N, pageSize=9" vertex="1">
