        <mxCell id="b_mount" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="BlogView.onMounted&#xa;loadPosts({ preferCache: true })" vertex="1">
